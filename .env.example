# ==================== 应用基础配置 ====================
DEBUG=false
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:5173"]

# ==================== LLM Provider配置 ====================
LLM_PROVIDER=openai
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2500
LLM_REQUEST_TIMEOUT=30

# 百度千帆
QIANFAN_API_KEY=
QIANFAN_SECRET_KEY=
QIANFAN_MODEL=ERNIE-4.0-8K
QIANFAN_API_BASE_URL=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-7-sonnet-latest
ANTHROPIC_BASE_URL=

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Moonshot (Kimi)
MOONSHOT_API_KEY=
MOONSHOT_MODEL=moonshot-v1-8k

# ==================== 应用 Prometheus / OTel / Langfuse ====================
ENABLE_OBSERVABILITY=true
ENABLE_METRICS=true
OTEL_ENABLED=true
OTEL_SERVICE_NAME=aviation-weather-agent
OTEL_SERVICE_NAMESPACE=aviation-weather
OTEL_ENVIRONMENT=development
# 本地启动应用 + docker compose 监控栈时默认指向 localhost
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORT_TIMEOUT_MS=10000
OTEL_EXCLUDED_URLS=metrics,docs,redoc,openapi.json
PHOENIX_PROJECT_NAME=aviation-weather-agent

LANGFUSE_ENABLED=true
LANGFUSE_BASE_URL=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-change-me
LANGFUSE_SECRET_KEY=sk-lf-change-me

# ==================== Grafana / Prometheus / Alertmanager ====================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
PROMETHEUS_APP_TARGET=host.docker.internal:8000

# ==================== Langfuse Self-hosted 初始化 ====================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-long-random-secret
SALT=replace-with-long-random-salt
ENCRYPTION_KEY=replace-with-64-char-hex-string

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=langfuse
POSTGRES_VERSION=17

CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=clickhouse

MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=miniosecret
REDIS_AUTH=myredissecret

LANGFUSE_INIT_ORG_ID=org-aviation
LANGFUSE_INIT_ORG_NAME=Aviation Weather
LANGFUSE_INIT_PROJECT_ID=proj-aviation-weather-agent
LANGFUSE_INIT_PROJECT_NAME=Aviation Weather Agent
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-change-me
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-change-me
LANGFUSE_INIT_USER_EMAIL=admin@example.com
LANGFUSE_INIT_USER_NAME=admin
LANGFUSE_INIT_USER_PASSWORD=change-me-now

# Phoenix
PHOENIX_RETENTION_DAYS=14
