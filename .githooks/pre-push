#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

if [[ "${SKIP_DEEPEVAL:-0}" =~ ^(1|true|yes|on)$ ]]; then
  echo "[pre-push] SKIP_DEEPEVAL 已开启，跳过 gate。"
  exit 0
fi

CHANGED_FILES="$(git diff --cached --name-only --diff-filter=ACMR)"
if [[ -z "$CHANGED_FILES" ]]; then
  exit 0
fi

if ! grep -Eq '^(app/|tests/|scripts/|requirements.*txt|\.github/workflows/pr-gate\.yml)' <<<"$CHANGED_FILES"; then
  echo "[pre-push] 未发现与 Agent/评测相关的暂存改动，跳过 DeepEval gate。"
  exit 0
fi

echo "[pre-push] 运行 DeepEval gate..."
chmod +x scripts/evals/run_eval.sh
scripts/evals/run_eval.sh
