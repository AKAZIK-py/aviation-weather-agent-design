# ==================== LLM Provider配置 ====================
# 当前使用的Provider (qianfan/openai/anthropic/deepseek/moonshot)
LLM_PROVIDER=qianfan

# LLM通用参数
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
LLM_REQUEST_TIMEOUT=30

# ==================== 百度千帆配置 ====================
BAIDU_API_KEY=your_api_key_here
BAIDU_SECRET_KEY=your_secret_key_here
BAIDU_MODEL_NAME=ERNIE-4.0-8K

# ==================== OpenAI配置 ====================
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4
# OPENAI_BASE_URL=https://api.openai.com/v1  # 可选，自定义API端点

# ==================== Anthropic配置 ====================
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-3-sonnet-20240229
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1  # 可选，自定义API端点

# ==================== DeepSeek配置 ====================
DEEPSEEK_API_KEY=your_deepseek_key_here
DEEPSEEK_MODEL=deepseek-chat
# DeepSeek自动使用 https://api.deepseek.com/v1

# ==================== Moonshot (Kimi)配置 ====================
MOONSHOT_API_KEY=your_moonshot_key_here
MOONSHOT_MODEL=moonshot-v1-8k
# Moonshot自动使用 https://api.moonshot.cn/v1

# ==================== 服务配置 ====================
DEBUG=false
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ==================== 监控配置 ====================
ENABLE_METRICS=true
METRICS_PORT=9090
